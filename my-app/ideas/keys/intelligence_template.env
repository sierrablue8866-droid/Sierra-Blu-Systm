# Sierra Blu Bot — Python environment
# Copy this to .env and fill in your values

# Sierra Blu Next.js backend
SIERRA_API_URL=http://localhost:3000

# Agent contact
AGENT_PHONE=+201061399688

# WhatsApp provider: "meta" or "twilio"
WHATSAPP_PROVIDER=meta
META_WA_PHONE_NUMBER_ID=
META_WA_ACCESS_TOKEN=

# Twilio (if using instead of Meta)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WA_FROM=whatsapp:+14155238886

# HubSpot CRM (free tier at hubspot.com)
HUBSPOT_API_KEY=
HUBSPOT_PIPELINE_ID=
HUBSPOT_STAGE_QUALIFY=

# Google Calendar
GOOGLE_SERVICE_ACCOUNT_JSON=./service_account.json
GOOGLE_CALENDAR_ID=primary

# Mixpanel (optional)
MIXPANEL_TOKEN=
