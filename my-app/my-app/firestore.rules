rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── BASE: Deny all by default ──────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ─── HELPER FUNCTIONS ───────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    // ─── PUBLIC COLLECTIONS ─────────────────────────────────────────
    // listings: public read (portal/landing/map), authenticated write
    match /listings/{listingId} {
      allow read:  if true;
      allow write: if isAuthenticated();
    }

    // proposals: public read via shareable concierge link
    match /proposals/{proposalId} {
      allow read:  if true;
      allow write: if isAuthenticated();
    }

    // concierge_selections: Stage 8 — shareable client pages
    match /concierge_selections/{selectionId} {
      allow read:  if true;
      allow write: if isAuthenticated();
    }

    // projects & developers: public catalog
    match /projects/{projectId} {
      allow read:  if true;
      allow write: if isAuthenticated();
    }
    match /developers/{developerId} {
      allow read:  if true;
      allow write: if isAuthenticated();
    }

    // zones: public — LiveInventoryMap reads this even for guests
    match /zones/{zoneId} {
      allow read:  if true;
      allow write: if isAuthenticated();
    }

    // vouchers: public read for redemption flow
    match /vouchers/{voucherId} {
      allow read:  if true;
      allow write: if isAuthenticated();
    }

    // ─── AUTHENTICATED COLLECTIONS (PII) ────────────────────────────
    // leads: contains PII (name, phone, budget) — authenticated only
    match /leads/{leadId} {
      allow read:   if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    match /clients/{clientId} {
      allow read:  if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /sales/{saleId} {
      allow read:  if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /activities/{activityId} {
      allow read:  if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /users/{userId} {
      allow read:   if isAuthenticated();
      allow update: if isAuthenticated() && request.auth.uid == userId;
      allow create: if isAuthenticated();
    }

    match /partners/{partnerId} {
      allow read:  if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /mediaAssets/{assetId} {
      allow read:  if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /viewings/{viewingId} {
      allow read:  if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // ─── PIPELINE COLLECTIONS ───────────────────────────────────────
    // broker_listings: Stage 1-2 WhatsApp/Telegram intake (Scribe)
    match /broker_listings/{msgId} {
      allow read:  if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // broker_messages: raw ingestion feed
    match /broker_messages/{msgId} {
      allow read:  if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // orchestration_logs: pipeline execution records per document
    match /orchestration_logs/{logId} {
      allow read:  if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // failed_orchestrations: DLQ — pipeline failures for manual review
    match /failed_orchestrations/{failId} {
      allow read:  if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // syncQueue / syncLog: PF sync engine
    match /syncQueue/{qId} {
      allow read:  if isAuthenticated();
      allow write: if isAuthenticated();
    }
    match /syncLog/{logId} {
      allow read:  if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // intelligence: global neural memory store
    match /intelligence/{docId} {
      allow read:  if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // ─── AUDIT ──────────────────────────────────────────────────────
    match /audit_logs/{logId} {
      allow create: if isAuthenticated();
      allow read:   if isAuthenticated();
      allow update: if false;   // immutable
      allow delete: if false;   // immutable
    }
  }
}
