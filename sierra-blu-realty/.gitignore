# For more information on ignoring files, see:
# https://help.github.com/articles/ignoring-files/

# ── Dependencies ──────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Test Coverage Reports ─────────────────────────────────
/coverage

# ── Application Build Output ──────────────────────────────
/.next/
/out/
/build

# ── Firebase Deployment & Artifacts ──────────────────────
/.firebase/
firebase-debug.log*

# ── OS & Editor Generated Files ──────────────────────────
.DS_Store
*.pem
.vscode/
.idea/

# ── Debug & Error Logs ───────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
build_log*.txt
build_output.log
dev_log_error.txt

# ── Environment Variables (opt-in to commit if needed) ───
.env*
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── Vercel Deployment ────────────────────────────────────
.vercel

# ── TypeScript Build Artifacts ───────────────────────────
*.tsbuildinfo
next-env.d.ts
